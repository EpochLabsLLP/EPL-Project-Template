{
  "template_version": "2.11.0",
  "template_repo": "Epoch Labs Project Template/_ProjectTemplate",
  "description": "Epoch Labs project template manifest. Declares file ownership for template sync.",
  "claude_md_structure_version": "2.2.0",
  "marketplace_registrations": {
    "extraKnownMarketplaces": {
      "anthropic-agent-skills": {
        "source": {
          "source": "github",
          "repo": "anthropics/skills"
        }
      }
    },
    "enabledPlugins": {
      "example-skills@anthropic-agent-skills": true
    }
  },
  "hook_registrations": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-resume.sh\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-compact.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/commit-gate.sh\"",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dep-gate.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/spec-gate.sh\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-frozen-files.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/spec-gate.sh\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/phase-scope.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/template-guard.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "categories": {
    "infrastructure": {
      "description": "Template-owned. Always overwritten on sync. Do not customize in projects.",
      "files": [
        ".claude/hooks/block-dangerous.sh",
        ".claude/hooks/commit-gate.sh",
        ".claude/hooks/dep-gate.sh",
        ".claude/hooks/protect-frozen-files.sh",
        ".claude/hooks/spec-gate.sh",
        ".claude/hooks/template-guard.sh",
        ".claude/hooks/session-start.sh",
        ".claude/hooks/session-resume.sh",
        ".claude/hooks/session-compact.sh",
        ".claude/hooks/parse_hook_input.py",
        ".claude/hooks/observe.sh",
        ".claude/hooks/checkpoint.sh",
        ".claude/hooks/aggregate_events.py",
        ".claude/hooks/detect_phase.py",
        ".claude/hooks/phase-scope.sh",
        ".claude/hooks/instance-id.sh",
        ".claude/hooks/progress-log.sh",
        ".claude/rules/change-control.md",
        ".claude/rules/execution-protocol.md",
        ".claude/rules/naming-conventions.md",
        ".claude/rules/problem-solving.md",
        ".claude/rules/intellectual-honesty.md",
        ".claude/rules/quality-gates.md",
        ".claude/rules/definition-of-done.md",
        ".claude/rules/spec-readiness.md",
        ".claude/skills/alignment-check/SKILL.md",
        ".claude/skills/code-review/SKILL.md",
        ".claude/skills/dep-check/SKILL.md",
        ".claude/skills/governance-health/SKILL.md",
        ".claude/skills/init-doc/SKILL.md",
        ".claude/skills/integration-logic/SKILL.md",
        ".claude/skills/module-complete/SKILL.md",
        ".claude/skills/wave-complete/SKILL.md",
        ".claude/skills/feature-complete/SKILL.md",
        ".claude/skills/pre-commit/SKILL.md",
        ".claude/skills/security-review/SKILL.md",
        ".claude/skills/spec-lookup/SKILL.md",
        ".claude/skills/template-migrate/SKILL.md",
        ".claude/skills/template-sync/SKILL.md",
        ".claude/skills/trace-check/SKILL.md",
        ".claude/skills/trace-check/scripts/validate_traceability.py",
        ".claude/skills/unlock-frozen/SKILL.md",
        ".claude/skills/mail/SKILL.md",
        ".claude/skills/rename-abbreviation/SKILL.md",
        ".claude/skills/work/SKILL.md",
        ".gitattributes",
        "template_sync.py",
        "TEMPLATE_MANIFEST.json",
        "CHANGELOG.md"
      ]
    },
    "template": {
      "description": "Reference/example files. Always overwritten on sync.",
      "files": [
        "Specs/TEMPLATE_PVD.md",
        "Specs/TEMPLATE_Product_Brief.md",
        "Specs/TEMPLATE_PRD.md",
        "Specs/TEMPLATE_Engineering_Spec.md",
        "Specs/TEMPLATE_UX_Spec.md",
        "Specs/TEMPLATE_Blueprint.md",
        "Specs/TEMPLATE_Work_Order.md",
        "Specs/TEMPLATE_Decision_Record.md",
        "Testing/TEMPLATE_Testing_Plans.md",
        "Sessions/SESSION_TEMPLATE.md",
        ".claude/settings.local.json.example"
      ]
    },
    "scaffolding": {
      "description": "Created once from template. Project-owned after creation. Never overwritten on sync.",
      "files": [
        "CLAUDE.md",
        "README.md",
        ".mcp.json",
        ".claude/phase-restrictions.json"
      ]
    },
    "managed_scaffolding": {
      "description": "Project-owned but with template-managed sections. Hooks and marketplace declarations are merged; permissions block is untouched.",
      "files": [
        ".claude/settings.json"
      ]
    },
    "generated": {
      "description": "Auto-generated by tools. Not managed by sync (regenerated by their own generators).",
      "files": [
        "Specs/Work_Ledger.md"
      ]
    }
  },
  "directories": [
    "Specs/",
    "Testing/",
    "WorkOrders/",
    "Sessions/",
    "Code/",
    "Research/",
    "Notes/"
  ]
}
