{
  "_comment": "SETUP: Copy this file to settings.local.json and customize for your machine.",
  "_comment2": "settings.local.json is gitignored — it holds per-machine permissions only.",
  "_comment3": "Permissions here MERGE with settings.json (which holds hooks).",
  "_comment4": "Safety net: block-dangerous.sh hook still catches destructive commands (rm -rf /, drop table, etc.).",

  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Task(*)",
      "Skill(*)",
      "NotebookEdit(*)",

      "WebSearch(*)",
      "WebFetch(*)",

      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*credential*)"
    ],
    "defaultMode": "acceptEdits"
  }
}
